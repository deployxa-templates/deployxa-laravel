{
    "name": "deployxa/laravel-template",
    "type": "project",
    "description": "Deployxa Laravel Template",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}
